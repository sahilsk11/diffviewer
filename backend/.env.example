GITHUB_TOKEN=
# GH_TOKEN= is also accepted. If neither is set, local development falls back
# to SAS/GitHub CLI locations such as /etc/<user>/secrets.env and
# ~/.config/gh/hosts.yml.
GITHUB_API_BASE_URL=https://api.github.com
DIFFVIEWER_DB_PATH=
DIFFVIEWER_CORS_ORIGINS=http://localhost:3000
CODEX_CLI_COMMAND=codex
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=120
